# ============================================================
# SpaceAI Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ============================================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=SpaceAI

# Auth
JWT_SECRET="your-super-secret-jwt-key-min-32-chars"

# Database — PostgreSQL (required for Vercel)
# Free options: neon.tech, supabase.com, railway.app
DATABASE_URL="postgresql://user:password@host:5432/spaceai?sslmode=require"
# For connection pooling (Neon/Supabase — same as DATABASE_URL if not using pooler)
DIRECT_URL="postgresql://user:password@host:5432/spaceai?sslmode=require"

# Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Stripe (for billing — add when ready)
# STRIPE_SECRET_KEY=sk_live_...
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# OpenAI (for AI design features — add when ready)
# OPENAI_API_KEY=sk-...

# AWS S3 (for image uploads — add when ready)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_S3_BUCKET=spaceai-uploads
